#!/bin/sh
set -e

if [ "$#" -ne 2 ]; then
    printf "Usage: %s ARTIFACT URL\n" "$0" >&2
    exit 2
fi

manifest="${REMOTE_ARTIFACTS_MANIFEST:-/tmp/remote-artifacts.sha256}"
artifact="$1"
url="$2"

curl -fsSL --retry 3 --retry-delay 5 "$url" -o "/tmp/${artifact}"
artifact_checksum=$(grep "  ${artifact}$" "$manifest")

(
    cd /tmp
    printf "%s\n" "${artifact_checksum}" | sha256sum -c -
)
