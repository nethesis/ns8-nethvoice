	--mount=type=cache,id=nethvoice-freepbx-npm,target=/root/.npm \
	--mount=type=cache,id=nethvoice-freepbx-yarn,target=/var/cache/yarn \
	cd /var/www/html/freepbx/rest/ && \
	sh /usr/local/bin/fetch-remote-artifact composer-2.9.8.phar https://getcomposer.org/download/2.9.8/composer.phar && \
	mv /tmp/composer-2.9.8.phar composer.phar && \
	COMPOSER_CACHE_DIR=/var/cache/composer COMPOSER_ALLOW_SUPERUSER=1 php composer.phar install --no-dev && \
	rm -fr README.md composer.json composer.lock composer.phar test && \
	cd /tmp/wizard && \
	npm_config_cache=/root/.npm npx -y -p npm@6 npm install yarn && node_modules/yarn/bin/yarn install --cache-folder /var/cache/yarn && node_modules/grunt-cli/bin/grunt build && \
	mkdir -p /var/www/html/freepbx/wizard && \
