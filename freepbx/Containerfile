	tar xzf /tmp/freepbx-framework-bootstrap-release-16.0.39.tar.gz --strip-components=1 -C /var/www/html/freepbx/admin/modules/framework && \
	rm -f /tmp/freepbx-framework-bootstrap-release-16.0.39.tar.gz && \
