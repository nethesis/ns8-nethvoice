# Download other modules
RUN install_module() { \
		module_url="${2}"; \
		module_archive="${1}-${module_url##*/}"; \
		module_dir="/var/www/html/freepbx/admin/modules/${1}"; \
		mkdir -p "${module_dir}" && \
		sh /usr/local/bin/fetch-remote-artifact "${module_archive}" "${module_url}" && \
		tar xzf "/tmp/${module_archive}" --strip-components=1 -C "${module_dir}" && \
		rm -f "/tmp/${module_archive}"; \
	}; \
	install_module announcement https://github.com/FreePBX/announcement/archive/refs/tags/release/16.0.7.tar.gz && \
	install_module arimanager https://github.com/FreePBX/arimanager/archive/refs/tags/release/16.0.13.tar.gz && \
	install_module asterisk-cli https://github.com/FreePBX/asterisk-cli/archive/refs/tags/release/16.0.8.tar.gz && \
	install_module asteriskinfo https://github.com/FreePBX/asteriskinfo/archive/refs/tags/release/16.0.10.tar.gz && \
	install_module backup https://github.com/FreePBX/backup/archive/refs/tags/release/16.0.70.3.tar.gz && \
	install_module blacklist https://github.com/FreePBX/blacklist/archive/refs/tags/release/16.0.21.tar.gz && \
	install_module bulkhandler https://github.com/FreePBX/bulkhandler/archive/refs/tags/release/16.0.16.tar.gz && \
	install_module calendar https://github.com/FreePBX/calendar/archive/refs/tags/release/16.0.34.2.tar.gz && \
	install_module callback https://github.com/FreePBX/callback/archive/refs/tags/release/16.0.4.tar.gz && \
	install_module callforward https://github.com/FreePBX/callforward/archive/refs/tags/release/16.0.6.tar.gz && \
	install_module callrecording https://github.com/FreePBX/callrecording/archive/refs/tags/release/16.0.22.tar.gz && \
