# Copy Asterisk files
COPY --from=builder /usr/src/asterisk/build/./ /
COPY remote-artifacts.sha256 /tmp/remote-artifacts.sha256
COPY fetch-remote-artifact /usr/local/bin/fetch-remote-artifact

RUN chown asterisk:asterisk \
	/var/lib/asterisk \
	/var/lib/asterisk/.gnupg \
	/var/lib/asterisk/agi-bin \
	/var/lib/asterisk/db \
	/var/lib/asterisk/sounds \
	/var/log/asterisk \
	/var/log/asterisk/cdr-csv \
	/var/log/asterisk/cdr-custom \
	/var/spool/asterisk/ \
	/var/spool/asterisk/monitor \
	/var/spool/asterisk/outgoing \
	/var/spool/asterisk/tmp \
	/var/spool/asterisk/uploads \
	/var/spool/asterisk/voicemail \
	/var/spool/asterisk/cache

RUN mkdir -p /var/lib/asterisk/sounds/nethcti \
    && sh /usr/local/bin/fetch-remote-artifact asterisk-sounds-de.tar.gz https://ns8.ams3.cdn.digitaloceanspaces.com/nethvoice/asterisk-sounds/asterisk-sounds-de.tar.gz \
    && sh /usr/local/bin/fetch-remote-artifact asterisk-sounds-en.tar.gz https://ns8.ams3.cdn.digitaloceanspaces.com/nethvoice/asterisk-sounds/asterisk-sounds-en.tar.gz \
    && sh /usr/local/bin/fetch-remote-artifact asterisk-sounds-es.tar.gz https://ns8.ams3.cdn.digitaloceanspaces.com/nethvoice/asterisk-sounds/asterisk-sounds-es.tar.gz \
    && sh /usr/local/bin/fetch-remote-artifact asterisk-sounds-fr.tar.gz https://ns8.ams3.cdn.digitaloceanspaces.com/nethvoice/asterisk-sounds/asterisk-sounds-fr.tar.gz \
    && sh /usr/local/bin/fetch-remote-artifact asterisk-sounds-it.tar.gz https://ns8.ams3.cdn.digitaloceanspaces.com/nethvoice/asterisk-sounds/asterisk-sounds-it.tar.gz \
    && tar xzf /tmp/asterisk-sounds-de.tar.gz -C /var/lib/asterisk/sounds \
    && tar xzf /tmp/asterisk-sounds-en.tar.gz -C /var/lib/asterisk/sounds \
    && tar xzf /tmp/asterisk-sounds-es.tar.gz -C /var/lib/asterisk/sounds \
    && tar xzf /tmp/asterisk-sounds-fr.tar.gz -C /var/lib/asterisk/sounds \
    && tar xzf /tmp/asterisk-sounds-it.tar.gz -C /var/lib/asterisk/sounds \
    && rm -f /tmp/asterisk-sounds-*.tar.gz \
    && chown -R asterisk:asterisk /var/lib/asterisk/sounds

COPY --chown=asterisk:asterisk etc/asterisk /etc/asterisk
