import json
import sys
import os

import agent

# get old environment from action
request = json.load(sys.stdin)
old_envs = request['environment']

# call configure module
response = agent.tasks.run(agent_id=os.environ['AGENT_ID'], action='configure-module', data={
    "nethvoice_host": old_envs["NETHVOICE_HOST"],
    "nethcti_ui_host": old_envs["NETHCTI_UI_HOST"],
    "reports_international_prefix": old_envs["REPORTS_INTERNATIONAL_PREFIX"],
    "timezone": old_envs["TIMEZONE"],
    "user_domain": old_envs["USER_DOMAIN"],
    "nethvoice_adm_username": old_envs.get("NETHVOICE_USER_PORTAL_USERNAME", ''),
    "nethvoice_adm_password": agent.read_envfile("passwords.env").get('NETHVOICE_USER_PORTAL_PASSWORD',""),
})

agent.assert_exp(response['exit_code'] == 0)

# restore hotel settings via set-nethvoice-hotel
fias_port = old_envs.get("NETHVOICE_HOTEL_FIAS_PORT", "")
response = agent.tasks.run(agent_id=os.environ['AGENT_ID'], action='set-nethvoice-hotel', data={
    "nethvoice_hotel": old_envs.get("NETHVOICE_HOTEL", "False") == "True",
    "nethvoice_hotel_fias_address": old_envs.get("NETHVOICE_HOTEL_FIAS_ADDRESS", ""),
    "nethvoice_hotel_fias_port": int(fias_port) if fias_port.isdigit() else "",
})

agent.assert_exp(response['exit_code'] == 0)

# restore satellite/transcription settings via set-integrations
passwords = agent.read_envfile("passwords.env")
response = agent.tasks.run(agent_id=os.environ['AGENT_ID'], action='set-integrations', data={
    "satellite_call_transcription_enabled": old_envs.get("SATELLITE_CALL_TRANSCRIPTION_ENABLED", 'False') == 'True',
    "satellite_voicemail_transcription_enabled": old_envs.get("SATELLITE_VOICEMAIL_TRANSCRIPTION_ENABLED", 'False') == 'True',
    "satellite_call_summary_enabled": old_envs.get("SATELLITE_CALL_SUMMARY_ENABLED", 'False') == 'True',
    "deepgram_api_key": passwords.get('DEEPGRAM_API_KEY', ''),
    "openai_api_key": passwords.get('OPENAI_API_KEY', ''),
})

agent.assert_exp(response['exit_code'] == 0)
