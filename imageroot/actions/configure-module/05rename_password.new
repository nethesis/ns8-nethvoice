set -e 
# redirect output to stder
exec 1>&2

# rename passwords.new to passwords.env, clone-module must have dynamic passwords
if [[ -f ./passwords.new ]]; then
    /usr/bin/mv -v ./passwords.new ./passwords.env
fi
