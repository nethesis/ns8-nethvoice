# Allocate new port for sftp service
import sys
import os
import subprocess
import agent

if not hasattr(agent, 'allocate_ports'):
    print(f"Core version too old, not allocating sftp port. Try on next update", file=sys.stderr)
    sys.exit(0)

# Read the env file, do not use real environment because it could be not updated
env = agent.read_envfile('environment')

# Set middleware environment variables if not already set (for updates from versions without middleware)
if 'NETHVOICE_MIDDLEWARE_PORT' not in env:
    # Allocate a new port for middleware if not set
    allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
    agent.set_env('NETHVOICE_MIDDLEWARE_PORT', str(allocated_ports[0]))
    agent.set_env('NETHVOICE_MIDDLEWARE_LISTEN_ADDRESS', '127.0.0.1:' + str(allocated_ports[0]))
elif 'ASTERISK_WSS_PORT' in env and env['NETHVOICE_MIDDLEWARE_PORT'] == env['ASTERISK_WSS_PORT']:
    # Fix port conflict: middleware and WSS are using the same port
    # This can happen on installations created with the buggy create-module script
    print(f"Detected port conflict: NETHVOICE_MIDDLEWARE_PORT and ASTERISK_WSS_PORT both using port {env['NETHVOICE_MIDDLEWARE_PORT']}", file=sys.stderr)

    # Comma separated TCP port list
    port_list	 = []
    port_range = os.environ['TCP_PORTS_RANGE'].split("-")

    # TCP ports
    for i in range(int(port_range[0]), int(port_range[1]) + 1):
        port_list.append(i)

    agent.set_env('NETHVOICE_MIDDLEWARE_PORT', str(port_list[35]))
    agent.set_env('NETHVOICE_MIDDLEWARE_LISTEN_ADDRESS', '127.0.0.1:' + str(port_list[35]))

# Check:
# skip allocation if the module has already allocated an extra port during an old update
if not 'ASTERISK_RECORDING_SFTP_PORT' in env:
	# If there are still old FLEXYSIP ports allocated, use one of them (REDIS_FLEXISIP_PORT, FLEXISIP_PORT, FLEXISIP_SIP_PORT)
	if 'REDIS_FLEXISIP_PORT' in env:
		sftp_port = env['REDIS_FLEXISIP_PORT']
		agent.unset_env('REDIS_FLEXISIP_PORT')
		print(f"Reusing old FLEXYSIP port for SFTP: {sftp_port}", file=sys.stderr)
	else:
		# Allocate a new port
		allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
		sftp_port = allocated_ports[0]
		print(f"New port allocated for SFTP: {sftp_port}", file=sys.stderr)
		# Open the port in the firewall
		agent.add_public_service(os.environ['MODULE_ID'], [str(sftp_port)+"/tcp"])
	# Update the environment file: this will be used as flag to avoid re-allocating the port
	agent.set_env('ASTERISK_RECORDING_SFTP_PORT', sftp_port)

# add port for asterisk ws
if not 'ASTERISK_WS_PORT' in env:
	if 'FLEXYSIP_PORT' in env:
		ws_port = env['FLEXYSIP_PORT']
		agent.unset_env('FLEXYSIP_PORT')
		print(f"Reusing old FLEXYSIP port for Asterisk WS: {ws_port}", file=sys.stderr)
	else:
		# Allocate a new port
		allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
		ws_port = allocated_ports[0]
		print(f"New port allocated for Asterisk WS: {ws_port}", file=sys.stderr)
	# Update the environment file
	agent.set_env('ASTERISK_WS_PORT', ws_port)

# add port for SATELLITE MQTT
if not 'SATELLITE_MQTT_PORT' in env:
	if 'FLEXYSIP_SIP_PORT' in env:
		mqtt_port = env['FLEXYSIP_SIP_PORT']
		agent.unset_env('FLEXYSIP_SIP_PORT')
		print(f"Reusing old FLEXYSIP port for SATELLITE MQTT: {mqtt_port}", file=sys.stderr)
	else:
		# Allocate a new port
		allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
		mqtt_port = allocated_ports[0]
		print(f"New port allocated for SATELLITE MQTT: {mqtt_port}", file=sys.stderr)
	# Update the environment file
	agent.set_env('SATELLITE_MQTT_PORT', mqtt_port)

# add port for HTTP REST API
if not 'SATELLITE_HTTP_PORT' in env:
	# Allocate a new port
	allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
	http_port = allocated_ports[0]
	print(f"New port allocated for SATELLITE HTTP: {http_port}", file=sys.stderr)
	# Update the environment file
	agent.set_env('SATELLITE_HTTP_PORT', http_port)

# Allocate RTP/UDP ports via ns8-core if:
# - UDP_PORTS_RANGE is absent (old instances that used the fake Redis-based allocation), OR
# - any of the five RTP env vars is missing
if 'UDP_PORTS_RANGE' not in env or any(env_name not in env for env_name in (
    'ASTERISK_RTPSTART',
    'ASTERISK_RTPEND',
    'JANUS_RTPSTART',
    'JANUS_RTPEND',
    'SATELLITE_RTP_PORT',
)):
	asterisk_rtp_ports = 1000
	janus_rtp_ports = 1000
	satellite_rtp_ports = 1
	rtp_start, rtp_end = agent.allocate_ports(
		asterisk_rtp_ports + janus_rtp_ports + satellite_rtp_ports,
		"udp",
	)
	# Set UDP_PORTS_RANGE so this migration block is not triggered again on
	# subsequent updates (ns8-core only sets this at install time, not here).
	agent.set_env('UDP_PORTS_RANGE', f'{rtp_start}-{rtp_end}')
	asterisk_rtp_start = rtp_start
	asterisk_rtp_end = asterisk_rtp_start + asterisk_rtp_ports - 1
	janus_rtp_start = asterisk_rtp_end + 1
	janus_rtp_end = janus_rtp_start + janus_rtp_ports - 1
	satellite_rtp_port = janus_rtp_end + 1

	print(f"New Asterisk RTP range allocated: {asterisk_rtp_start}-{asterisk_rtp_end}", file=sys.stderr)
	print(f"New Janus RTP range allocated: {janus_rtp_start}-{janus_rtp_end}", file=sys.stderr)
	print(f"New port allocated for SATELLITE RTP: {satellite_rtp_port}", file=sys.stderr)
	agent.set_env('ASTERISK_RTPSTART', asterisk_rtp_start)
	agent.set_env('ASTERISK_RTPEND', asterisk_rtp_end)
	agent.set_env('JANUS_RTPSTART', janus_rtp_start)
	agent.set_env('JANUS_RTPEND', janus_rtp_end)
	agent.set_env('SATELLITE_RTP_PORT', satellite_rtp_port)

	# Open the new RTP ranges in the firewall (replaces old entries for these ranges)
	agent.add_public_service(os.environ['MODULE_ID'], [
		str(asterisk_rtp_start)+"-"+str(asterisk_rtp_end)+"/udp",
		str(janus_rtp_start)+"-"+str(janus_rtp_end)+"/udp",
	])

	# Update Asterisk RTP settings in MariaDB so they match the new port range.
	# This is needed because docker-entrypoint-initdb.d only runs on fresh DB init.
	# MariaDB is guaranteed to be running at this point (before 80restart).
	mariadb_check = subprocess.run(
		['systemctl', '--user', 'is-active', 'mariadb'],
		capture_output=True, text=True,
	)
	if mariadb_check.returncode != 0:
		print("Error: MariaDB is not running, cannot update Asterisk RTP range in DB. Aborting migration.", file=sys.stderr)
		sys.exit(1)
	passwords = agent.read_envfile('passwords.env')
	mariadb_root_password = passwords.get('MARIADB_ROOT_PASSWORD', '')
	if not mariadb_root_password:
		print("Error: MARIADB_ROOT_PASSWORD is empty, cannot update Asterisk RTP in MariaDB. Aborting migration.", file=sys.stderr)
		sys.exit(1)
	mariadb_port = os.environ.get('NETHVOICE_MARIADB_PORT', '3306')
	rtp_sql = (
		f"UPDATE sipsettings SET data='{asterisk_rtp_start}' WHERE keyword='rtpstart';"
		f"UPDATE sipsettings SET data='{asterisk_rtp_end}' WHERE keyword='rtpend';"
		f"UPDATE kvstore_Sipsettings SET val='{asterisk_rtp_start}' WHERE `key`='rtpstart';"
		f"UPDATE kvstore_Sipsettings SET val='{asterisk_rtp_end}' WHERE `key`='rtpend';"
	)
	proc = subprocess.run(
		['podman', 'exec', '-i', 'mariadb',
		 'mysql', '-uroot', f'-p{mariadb_root_password}',
		 '-h', '127.0.0.1', '-P', mariadb_port, 'asterisk'],
		input=rtp_sql, text=True, capture_output=True,
	)
	if proc.returncode == 0:
		print(f"Updated Asterisk RTP range in MariaDB: {asterisk_rtp_start}-{asterisk_rtp_end}", file=sys.stderr)
	else:
		print(f"Warning: failed to update Asterisk RTP in MariaDB: {proc.stderr}", file=sys.stderr)

# add port for Asterisk WSS
if not 'ASTERISK_WSS_PORT' in env:
	allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
	wss_port = allocated_ports[0]
	print(f"New port allocated for Asterisk WSS: {wss_port}", file=sys.stderr)
	agent.set_env('ASTERISK_WSS_PORT', wss_port)
	# Open the port in the firewall
	agent.add_public_service(os.environ['MODULE_ID'], [str(wss_port)+"/tcp"])
	# Add Asterisk RTP port range for WSS
	agent.add_public_service(os.environ['MODULE_ID'], [str(os.environ['ASTERISK_RTPSTART'])+"-"+str(os.environ['ASTERISK_RTPEND'])+"/udp"])

if not 'SATELLITE_PGSQL_PORT' in env:
	allocated_ports = agent.allocate_ports(1, "tcp", keep_existing=True)
	pgsql_port = allocated_ports[0]
	print(f"New port allocated for SATELLITE PGSQL: {pgsql_port}", file=sys.stderr)
	agent.set_env('SATELLITE_PGSQL_PORT', pgsql_port)

# Allocate dedicated UDP port for SIP UDP binding if not already set
if 'ASTERISK_SIP_UDP_PORT' not in env:
	sip_udp = agent.allocate_ports(1, "udp", keep_existing=True)
	sip_udp_port = sip_udp[0]
	print(f"New UDP port allocated for Asterisk SIP UDP: {sip_udp_port}", file=sys.stderr)
	agent.set_env('ASTERISK_SIP_UDP_PORT', sip_udp_port)
