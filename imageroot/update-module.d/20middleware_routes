import os
import sys
import agent
import agent.tasks

# Configure middleware routes if middleware environment variables are set
if (os.getenv('NETHVOICE_MIDDLEWARE_PORT') and 
    os.getenv('NETHVOICE_HOST') and 
    os.getenv('NETHCTI_UI_HOST')):

    # Find default traefik instance for current node
    default_traefik_id = agent.resolve_agent_id('traefik@node')
    if default_traefik_id is None:
        print("Warning: Traefik not found, skipping middleware route configuration", file=sys.stderr)
        sys.exit(0)

    lets_encrypt = os.getenv('TRAEFIK_LETS_ENCRYPT', 'false')

    # Configure middleware API route on NETHVOICE_HOST
    response = agent.tasks.run(
        agent_id=default_traefik_id,
        action='set-route',
        data={
            'instance': os.environ['MODULE_ID'] + '-server-api',
            'url':  'http://127.0.0.1:' + os.environ["NETHVOICE_MIDDLEWARE_PORT"],
            'http2https':  os.environ["TRAEFIK_HTTP2HTTPS"] == "true",
            'lets_encrypt': lets_encrypt == 'True',
            'host': os.environ["NETHVOICE_HOST"],
            'path': '/api',
            'strip_prefix': True,
            'headers': {
                'response': {
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Credentials': "true",
                    'Access-Control-Allow-Headers': '*'
                }
            }
        },
    )
    if response['exit_code'] != 0:
        print(f"Warning: Failed to configure middleware API route on {os.environ['NETHVOICE_HOST']}", file=sys.stderr)

    # Configure middleware API route on NETHCTI_UI_HOST
    response = agent.tasks.run(
        agent_id=default_traefik_id,
        action='set-route',
        data={
            'instance': os.environ['MODULE_ID'] + '-cti-server-api',
            'url':  'http://127.0.0.1:' + os.environ["NETHVOICE_MIDDLEWARE_PORT"],
            'http2https':  os.environ["TRAEFIK_HTTP2HTTPS"] == "true",
            'lets_encrypt': lets_encrypt == 'True',
            'host': os.environ["NETHCTI_UI_HOST"],
            'path': '/api',
            'strip_prefix': True,
            'headers': {
                'response': {
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Credentials': "true",
                    'Access-Control-Allow-Headers': '*'
                }
            }
        },
    )
    if response['exit_code'] != 0:
        print(f"Warning: Failed to configure middleware API route on {os.environ['NETHCTI_UI_HOST']}", file=sys.stderr)

    # Configure middleware websocket route
    response = agent.tasks.run(
        agent_id=default_traefik_id,
        action='set-route',
        data={
            'instance': os.environ['MODULE_ID'] + '-server-websocket',
            'url':  'http://127.0.0.1:' + os.environ["NETHVOICE_MIDDLEWARE_PORT"] + os.environ["NETHVOICE_MIDDLEWARE_V1_WS_PATH"],
            'http2https':  os.environ["TRAEFIK_HTTP2HTTPS"] == "true",
            'lets_encrypt': lets_encrypt == 'True',
            'host': os.environ["NETHCTI_UI_HOST"],
            'path': '/socket.io',
            'headers': {
                'response': {
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Credentials': "true",
                    'Access-Control-Allow-Headers': '*'
                }
            }
        },
    )
    if response['exit_code'] != 0:
        print(f"Warning: Failed to configure middleware websocket route", file=sys.stderr)

    print("Middleware routes configured successfully", file=sys.stderr)
else:
    print("Middleware environment variables not set, skipping route configuration", file=sys.stderr)
